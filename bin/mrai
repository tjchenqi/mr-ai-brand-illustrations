#!/usr/bin/env python3
"""Small CLI helper for Mr.Ai illustration packages.

The CLI is intentionally lightweight: it creates a structured validation package
from a script, proposes shot anchors with deterministic heuristics, and writes
prompt files for agents or image-generation tools to refine.
"""

from __future__ import annotations

import argparse
from dataclasses import dataclass
import base64
import datetime as dt
import hashlib
import json
import re
import shutil
import subprocess
import textwrap
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_ROUTING_PATH = REPO_ROOT / "agent-pack" / "visual-routing-rules.json"
DEFAULT_LAYOUT_LIBRARY_PATH = REPO_ROOT / "agent-pack" / "layout-library.json"
DEFAULT_TREATMENT_RULES_PATH = REPO_ROOT / "agent-pack" / "treatment-rules.json"
DEFAULT_AV_SCHEMA_PATH = REPO_ROOT / "agent-pack" / "audio-visual-map.schema.json"
DEFAULT_REFERENCE_IMAGE_PATH = REPO_ROOT / "assets" / "brand-references" / "MrAi_logo.png"
JOB_STORE_DIRNAME = ".mrai-jobs"
SUPPORTED_RECORD_FORMATS = {"9x16", "16x9"}
JOB_STATUSES = {"pending", "running", "completed", "failed"}
QA_STATUSES = {"pass", "warning", "failed", "needs_human_review"}
ERROR_CODES = {"provider_missing", "provider_failed", "qa_failed", "invalid_record", "timeout"}
MMX_PROMPT_TARGET_CHARS = 1400
PROVIDER_ERROR_SNIPPET_CHARS = 500
MOCK_PNG_BASE64 = (
    "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAFgwJ/"
    "lQx7WQAAAABJRU5ErkJggg=="
)


SAFE_AREA_TEMPLATES = {
    "left_text_safe": [{"x": 0.0, "y": 0.0, "w": 0.38, "h": 1.0}],
    "right_text_safe": [{"x": 0.62, "y": 0.0, "w": 0.38, "h": 1.0}],
    "top_subtitle_safe": [{"x": 0.06, "y": 0.0, "w": 0.88, "h": 0.18}],
    "bottom_subtitle_safe": [{"x": 0.06, "y": 0.78, "w": 0.88, "h": 0.2}],
    "center_character_safe": [{"x": 0.18, "y": 0.18, "w": 0.64, "h": 0.64}],
    "actor_top_subtitle_bottom": [{"x": 0.06, "y": 0.76, "w": 0.88, "h": 0.22}],
}


@dataclass
class ScriptSegment:
    role: str
    number: str
    title: str
    body: str
    raw_title: str
    index: int
    visual_override: dict[str, str] | None = None

    @property
    def segment_id(self) -> str:
        return f"{self.role}{self.number}" if self.number else f"S{self.index}"

    @property
    def override(self) -> dict[str, str]:
        return self.visual_override or {}


class MmxProviderError(RuntimeError):
    def __init__(self, message: str, subject_ref_failed: bool = False):
        super().__init__(message)
        self.subject_ref_failed = subject_ref_failed


def read_input(value: str) -> str:
    path = Path(value).expanduser()
    if path.exists():
        return path.read_text(encoding="utf-8")
    return value


def load_json_config(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def validation_error(message: str) -> str:
    return f"ERROR: {message}"


def validate_allowed(errors: list[str], value, allowed, label: str) -> None:
    if value not in allowed:
        errors.append(validation_error(f"{label}: {value!r} not in {allowed!r}"))


def validate_av_map(data: dict, schema: dict) -> list[str]:
    errors: list[str] = []
    for key in schema["top_level_required"]:
        if key not in data:
            errors.append(validation_error(f"missing top-level field {key}"))
    if errors:
        return errors

    validate_allowed(errors, data.get("style_preset"), schema["enums"]["top_level.style_preset"], "style_preset")

    selected_host_ids: set[str] = set()
    for index, segment in enumerate(data.get("segments", []), start=1):
        if not isinstance(segment, dict):
            errors.append(validation_error(f"segment[{index}] must be an object"))
            continue
        label = segment.get("segment_id", f"segment[{index}]")
        for key in schema["segment_required"]:
            if key not in segment:
                errors.append(validation_error(f"{label} missing {key}"))
        validate_allowed(errors, segment.get("role"), schema["enums"]["segment.role"], f"{label}.role")
        validate_allowed(errors, segment.get("visual_treatment"), schema["enums"]["segment.visual_treatment"], f"{label}.visual_treatment")
        validate_allowed(errors, segment.get("cognitive_role"), schema["enums"]["segment.cognitive_role"], f"{label}.cognitive_role")
        validate_allowed(errors, segment.get("expression_pace"), schema["enums"]["segment.expression_pace"], f"{label}.expression_pace")
        validate_allowed(errors, segment.get("timing"), schema["enums"]["segment.timing"], f"{label}.timing")
        if not isinstance(segment.get("selected_for_image"), bool):
            errors.append(validation_error(f"{label}.selected_for_image must be boolean"))
        if segment.get("role") == "quoted_source":
            if segment.get("cognitive_role") != "quote_source":
                errors.append(validation_error(f"{label} quoted_source must use cognitive_role=quote_source"))
            if segment.get("visual_treatment") != "quote-card-or-overlay":
                errors.append(validation_error(f"{label} quoted_source must use visual_treatment=quote-card-or-overlay"))
        if segment.get("role") == "host_voiceover" and segment.get("selected_for_image"):
            selected_host_ids.add(segment.get("segment_id"))

    for index, shot in enumerate(data.get("shots", []), start=1):
        if not isinstance(shot, dict):
            errors.append(validation_error(f"shot[{index}] must be an object"))
            continue
        label = shot.get("shot_id", f"shot[{index}]")
        for key in schema["shot_required"]:
            if key not in shot:
                errors.append(validation_error(f"{label} missing {key}"))
        validate_allowed(errors, shot.get("segment_role"), schema["enums"]["shot.segment_role"], f"{label}.segment_role")
        if shot.get("formats") != schema["enums"]["shot.formats"]:
            errors.append(validation_error(f"{label}.formats must be {schema['enums']['shot.formats']!r}"))
        if shot.get("asset_slots") != {
            "16x9": f"16x9/{shot.get('shot_id')}-16x9.png",
            "9x16": f"9x16/{shot.get('shot_id')}-9x16.png",
        }:
            errors.append(validation_error(f"{label}.asset_slots must match recommended 16x9/9x16 asset paths"))
        validate_allowed(errors, shot.get("style_preset"), schema["enums"]["shot.style_preset"], f"{label}.style_preset")
        validate_allowed(errors, shot.get("expression_pace"), schema["enums"]["shot.expression_pace"], f"{label}.expression_pace")
        validate_allowed(errors, shot.get("timing"), schema["enums"]["shot.timing"], f"{label}.timing")
        if shot.get("segment_id") not in selected_host_ids:
            errors.append(validation_error(f"{label}.segment_id must reference a selected host_voiceover segment"))
        if not isinstance(shot.get("short_labels"), list):
            errors.append(validation_error(f"{label}.short_labels must be a list"))

    return errors


def validate_asset_manifest(package_path: Path, av_map: dict | None = None) -> list[str]:
    errors: list[str] = []
    manifest_path = package_path / "asset-manifest.json"
    if not manifest_path.exists():
        return [validation_error("missing package file asset-manifest.json")]
    try:
        manifest = load_json_config(manifest_path)
    except json.JSONDecodeError as exc:
        return [validation_error(f"invalid asset-manifest.json: {exc}")]
    assets = manifest.get("assets")
    if not isinstance(assets, list):
        return [validation_error("asset-manifest.json assets must be a list")]
    if av_map is None:
        return errors
    shots_by_id = {shot.get("shot_id"): shot for shot in av_map.get("shots", [])}
    manifest_by_id = {asset.get("shot_id"): asset for asset in assets if isinstance(asset, dict)}
    if set(shots_by_id) != set(manifest_by_id):
        errors.append(validation_error("asset-manifest.json shot ids must match audio-visual-map.json shots"))
    for shot_id, shot in shots_by_id.items():
        asset = manifest_by_id.get(shot_id)
        if not asset:
            continue
        if asset.get("asset_slots") != shot.get("asset_slots"):
            errors.append(validation_error(f"asset-manifest {shot_id} asset_slots must match audio-visual-map"))
        if asset.get("status") not in {"pending_generation", "generated", "accepted", "rejected"}:
            errors.append(validation_error(f"asset-manifest {shot_id} status is invalid"))
    return errors


def validate_package(package_path: Path, schema_path: Path) -> list[str]:
    errors: list[str] = []
    av_map_path = package_path / "audio-visual-map.json"
    required_files = [
        "source-script.md",
        "shot-list.md",
        "image-prompts.md",
        "timeline-plan.md",
        "audio-visual-map.json",
        "asset-manifest.json",
        "qa-report.md",
        "remotion-overlay-notes.md",
        "validation-notes.md",
    ]
    for filename in required_files:
        if not (package_path / filename).exists():
            errors.append(validation_error(f"missing package file {filename}"))
    for dirname in ["16x9", "9x16"]:
        if not (package_path / dirname).is_dir():
            errors.append(validation_error(f"missing package directory {dirname}/"))
    if not av_map_path.exists():
        return errors
    try:
        data = load_json_config(av_map_path)
        schema = load_json_config(schema_path)
    except json.JSONDecodeError as exc:
        return errors + [validation_error(f"invalid JSON: {exc}")]
    errors.extend(validate_av_map(data, schema))
    errors.extend(validate_asset_manifest(package_path, data))
    return errors


def asset_inventory(package_path: Path) -> tuple[list[str], list[str]]:
    """Return human-readable asset slot lines and structural errors."""
    errors: list[str] = []
    manifest_path = package_path / "asset-manifest.json"
    if not manifest_path.exists():
        return [], [validation_error("missing package file asset-manifest.json")]
    try:
        manifest = load_json_config(manifest_path)
    except json.JSONDecodeError as exc:
        return [], [validation_error(f"invalid asset-manifest.json: {exc}")]
    assets = manifest.get("assets")
    if not isinstance(assets, list):
        return [], [validation_error("asset-manifest.json assets must be a list")]

    lines: list[str] = []
    for asset in assets:
        if not isinstance(asset, dict):
            errors.append(validation_error("asset-manifest asset must be an object"))
            continue
        shot_id = asset.get("shot_id", "unknown-shot")
        status = asset.get("status", "unknown")
        slots = asset.get("asset_slots", {})
        if not isinstance(slots, dict):
            errors.append(validation_error(f"{shot_id}.asset_slots must be an object"))
            continue
        lines.append(f"{shot_id} [{status}]")
        for fmt in ["16x9", "9x16"]:
            rel = slots.get(fmt)
            if not rel:
                errors.append(validation_error(f"{shot_id}.asset_slots missing {fmt}"))
                continue
            exists = (package_path / rel).exists()
            marker = "ok" if exists else "missing"
            lines.append(f"  {fmt}: {marker} {rel}")
    return lines, errors


def utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def read_json_file(path: Path) -> object:
    return json.loads(path.read_text(encoding="utf-8"))


def write_json_file(path: Path, data: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def normalize_records_payload(payload: object) -> list[dict]:
    if isinstance(payload, list):
        records = payload
    elif isinstance(payload, dict) and isinstance(payload.get("records"), list):
        records = payload["records"]
    else:
        raise ValueError("records input must be a list or an object with records[]")
    return records


def validate_records(records: list[dict]) -> list[str]:
    errors: list[str] = []
    required = ["s_id", "audience_takeaway", "visual_intent"]
    for index, record in enumerate(records, start=1):
        label = record.get("s_id") if isinstance(record, dict) else f"record[{index}]"
        if not isinstance(record, dict):
            errors.append(validation_error(f"record[{index}] must be an object"))
            continue
        for key in required:
            if not str(record.get(key, "")).strip():
                errors.append(validation_error(f"{label} missing required field {key}"))
        fmt = record.get("format", "9x16")
        if fmt == "both":
            errors.append(validation_error(f"{label}.format=both is not supported in V1.1; submit one 9x16 or 16x9 record at a time"))
        elif fmt not in SUPPORTED_RECORD_FORMATS:
            errors.append(validation_error(f"{label}.format must be one of {sorted(SUPPORTED_RECORD_FORMATS)!r}"))
    return errors


def job_store_root(base: Path) -> Path:
    return base / JOB_STORE_DIRNAME


def job_path_for(root: Path, job_id: str) -> Path:
    return job_store_root(root) / job_id


def load_job(job_dir: Path) -> dict:
    return load_json_config(job_dir / "job.json")


def save_job(job_dir: Path, job: dict) -> None:
    job["updated_at"] = utc_now()
    write_json_file(job_dir / "job.json", job)


def append_event(job_dir: Path, event: dict) -> None:
    event = {"ts": utc_now(), **event}
    with (job_dir / "events.jsonl").open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(event, ensure_ascii=False) + "\n")


def stable_json(data: object) -> str:
    return json.dumps(data, ensure_ascii=False, sort_keys=True, separators=(",", ":"))


def hash_reference_image(path_value: str | None) -> str | None:
    if not path_value:
        return None
    path = Path(path_value).expanduser()
    if not path.exists():
        return f"missing:{path_value}"
    digest = hashlib.sha256()
    digest.update(path.read_bytes())
    return digest.hexdigest()


def resolve_reference_image(path_value: str | None) -> Path:
    path = Path(path_value).expanduser() if path_value else DEFAULT_REFERENCE_IMAGE_PATH
    if not path.is_absolute():
        path = (REPO_ROOT / path).resolve()
    else:
        path = path.resolve()
    if not path.exists():
        raise FileNotFoundError(f"reference_image not found: {path}")
    return path


def record_cache_payload(record: dict, backend_config: dict) -> dict:
    reference_image = record.get("reference_image")
    return {
        "record": record,
        "reference_image_hash": hash_reference_image(reference_image),
        "backend_config": backend_config,
    }


def cache_key_for_record(record: dict, backend_config: dict) -> str:
    return hashlib.sha256(stable_json(record_cache_payload(record, backend_config)).encode("utf-8")).hexdigest()


def safe_area_template_for_record(record: dict) -> str:
    layout = str(record.get("layout", "")).lower()
    intent = str(record.get("visual_intent", "")).lower()
    text = layout + " " + intent
    if any(keyword in text for keyword in ["actor_top_subtitle_bottom", "actor top", "人物上方", "字幕下方"]):
        return "actor_top_subtitle_bottom"
    if any(keyword in text for keyword in ["left", "左"]):
        return "left_text_safe"
    if any(keyword in text for keyword in ["right", "右"]):
        return "right_text_safe"
    if any(keyword in text for keyword in ["top", "上"]):
        return "top_subtitle_safe"
    if any(keyword in text for keyword in ["center", "中间", "中心"]):
        return "center_character_safe"
    return "bottom_subtitle_safe"


def normalize_record_defaults(record: dict) -> dict:
    item = dict(record)
    item.setdefault("format", "9x16")
    item["reference_image"] = str(resolve_reference_image(item.get("reference_image")))
    return item


def normalize_list(value) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        return [str(item).strip() for item in value if str(item).strip()]
    return [item.strip() for item in str(value).split("|") if item.strip()]


def overlay_labels_for_record(record: dict) -> list[str]:
    return normalize_list(record.get("labels"))


def compact_text(value, max_chars: int) -> str:
    text = re.sub(r"\s+", " ", str(value or "")).strip()
    if len(text) <= max_chars:
        return text
    return text[: max(0, max_chars - 1)].rstrip() + "..."


def compact_join(value, max_chars: int, fallback: str) -> str:
    items = normalize_list(value)
    if not items:
        return fallback
    return compact_text(", ".join(items), max_chars)


def clamp_prompt(prompt: str, max_chars: int = MMX_PROMPT_TARGET_CHARS) -> str:
    if len(prompt) <= max_chars:
        return prompt
    keep = max_chars - len("\n[trimmed]")
    return prompt[:keep].rstrip() + "\n[trimmed]"


def prompt_for_record(record: dict) -> str:
    labels = overlay_labels_for_record(record)
    key_elements = compact_join(record.get("key_elements"), 160, "one simple physical metaphor")
    negative_elements = compact_join(record.get("negative_elements"), 120, "robot face, monk, formal business presenter")
    fmt = record.get("format", "9x16")
    orientation = "9:16 vertical" if fmt == "9x16" else "16:9 horizontal"
    mode = record.get("mode", "auto")
    layout = record.get("layout", "auto physical metaphor")
    style_guidance = {
        "explainer-sketch": "whiteboard sketch, white background, thin black marker, sparse props, rough hand-drawn feel",
        "brand": "colored cartoon brand IP, white/light background, restrained blue/yellow palette, dark outlines",
        "background": "quiet reusable background, large clean overlay space, restrained brand palette",
        "auto": "colored Mr.Ai brand IP plus sparse explanatory sketch logic, white/light background",
    }.get(mode, "colored Mr.Ai brand IP plus sparse explanatory sketch logic")
    prompt = textwrap.dedent(
        f"""\
        Mr.Ai image for AI 闲僧. Format: {orientation}. Mode: {mode}. Layout: {compact_text(layout, 80)}.
        Scene intent: {compact_text(record.get("visual_intent", ""), 260)}
        Audience takeaway: {compact_text(record.get("audience_takeaway", ""), 220)}
        Required elements: {key_elements}.
        Overlay labels are for post-production only: {compact_text(", ".join(labels) if labels else "blank label spaces", 120)}.
        Character: use the subject reference image as identity source. Preserve Mr.Ai: friendly middle-aged cartoon explainer, rounded face, baseball cap with curved brim, clear dark/gray mustache, blue shirt, yellow brand accent, thick dark outline. Do not redesign him as realistic man, flat-vector generic person, robot, monk, child, or business presenter.
        Style: {style_guidance}. Simple physical metaphor, clean composition, no glossy sci-fi UI.
        Text rule: render NO text of any kind. No Chinese, English, fake letters, numbers, captions, labels, UI text, or pseudo-writing. Leave cards/signs/labels blank for later overlay.
        Avoid: formula, equation, plus-sign formula, PPT infographic, dense architecture diagram, realistic UI screenshot, robot face, {negative_elements}.
        """
    ).strip()
    return clamp_prompt(prompt)


def image_meta_for(path: Path) -> dict:
    fmt = path.suffix.lower().lstrip(".") or "png"
    return {
        "width": None,
        "height": None,
        "format": fmt,
        "color_space": "unknown",
        "bytes": path.stat().st_size if path.exists() else 0,
    }


def next_version_for(out_dir: Path, s_id: str, fmt: str, force: bool) -> int:
    safe_id = slugify(s_id).upper() or "S"
    existing = sorted(out_dir.glob(f"{safe_id}_v*_{fmt}.*"))
    if not existing:
        return 1
    versions = []
    for path in existing:
        match = re.search(r"_v(\d+)_", path.name)
        if match:
            versions.append(int(match.group(1)))
    latest = max(versions or [1])
    return latest + 1 if force else latest


def result_filename(s_id: str, version: int, fmt: str, ext: str = "png") -> str:
    safe_id = slugify(s_id).upper() or "S"
    return f"{safe_id}_v{version}_{fmt}.{ext}"


def qa_checks_for_result(record: dict, image_path: str | None, provider_ok: bool) -> dict:
    return {
        "character_consistency": "needs_human_review",
        "layout_match": "needs_human_review",
        "no_chinese_bitmap_text": "pass",
        "safe_area_available": "pass",
        "metaphor_clarity": "needs_human_review",
        "provider_result": "pass" if provider_ok and image_path else "failed",
    }


def build_result(
    record: dict,
    image_path: str | None,
    version: int,
    cache_hit: bool,
    backend: str,
    prompt: str,
    seed: int,
    attempt: int,
    error_code: str | None = None,
    error_message: str | None = None,
    qa_status_override: str | None = None,
    subject_ref_failed: bool = False,
) -> dict:
    safe_template = safe_area_template_for_record(record)
    provider_ok = image_path is not None and error_code is None
    qa_status = qa_status_override or ("needs_human_review" if provider_ok else "failed")
    path = Path(image_path) if image_path else None
    usable = provider_ok and qa_status in {"pass", "warning"}
    subject_ref_requested = backend == "mmx" and bool(record.get("reference_image"))
    return {
        "s_id": record.get("s_id"),
        "beat_ref": record.get("beat_ref"),
        "format": record.get("format", "9x16"),
        "image_path": image_path,
        "image_meta": image_meta_for(path) if path else {"width": None, "height": None, "format": None, "color_space": "unknown", "bytes": 0},
        "layout_used": record.get("layout") or "auto",
        "mode_used": record.get("mode") or "auto",
        "safe_areas": SAFE_AREA_TEMPLATES[safe_template],
        "composition_template_id": safe_template,
        "usable": usable,
        "qa_status": qa_status,
        "qa_checks": qa_checks_for_result(record, image_path, provider_ok),
        "generation_meta": {
            "prompt": prompt,
            "backend": backend,
            "model": "image-01" if backend == "mmx" else "mock",
            "region": "cn" if backend == "mmx" else None,
            "seed": seed,
            "timestamp": utc_now(),
            "attempt": attempt,
            "prompt_chars": len(prompt),
            "prompt_limit": MMX_PROMPT_TARGET_CHARS if backend == "mmx" else None,
            "reference_image": record.get("reference_image"),
            "subject_ref_requested": subject_ref_requested,
            "subject_ref_used": subject_ref_requested and not subject_ref_failed,
            "subject_ref_failed": subject_ref_failed,
        },
        "version": version,
        "cache_hit": cache_hit,
        "error_code": error_code,
        "error_message": error_message,
        "overlay_labels": overlay_labels_for_record(record),
    }


def provider_error_excerpt(exc: subprocess.CalledProcessError) -> str:
    pieces = []
    stderr = compact_text(getattr(exc, "stderr", "") or "", PROVIDER_ERROR_SNIPPET_CHARS)
    stdout = compact_text(getattr(exc, "stdout", "") or "", PROVIDER_ERROR_SNIPPET_CHARS)
    if stderr:
        pieces.append(f"stderr: {stderr}")
    if stdout:
        pieces.append(f"stdout: {stdout}")
    if not pieces:
        pieces.append(str(exc))
    return "; ".join(pieces)


def write_mock_image(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_bytes(base64.b64decode(MOCK_PNG_BASE64))


def mmx_output_for(out_dir: Path, out_prefix: str) -> Path:
    candidates = sorted(out_dir.glob(f"{out_prefix}*"))
    if not candidates:
        raise RuntimeError("mmx completed but produced no output file")
    return candidates[-1]


def build_mmx_command(
    prompt: str,
    out_dir: Path,
    out_prefix: str,
    fmt: str,
    seed: int,
    reference_image: str | None = None,
) -> list[str]:
    aspect = "9:16" if fmt == "9x16" else "16:9"
    cmd = [
        "mmx",
        "image",
        "generate",
        "--region",
        "cn",
        "--aspect-ratio",
        aspect,
        "--out-dir",
        str(out_dir),
        "--out-prefix",
        out_prefix,
        "--seed",
        str(seed),
        "--prompt",
        prompt,
    ]
    if reference_image:
        cmd.extend(["--subject-ref", f"type=character,image={reference_image}"])
    return cmd


def run_mmx_provider(prompt: str, out_dir: Path, out_prefix: str, fmt: str, seed: int, timeout_seconds: int, reference_image: str | None = None) -> tuple[Path, bool]:
    if shutil.which("mmx") is None:
        raise FileNotFoundError("mmx CLI not found")
    out_dir.mkdir(parents=True, exist_ok=True)
    cmd = build_mmx_command(prompt, out_dir, out_prefix, fmt, seed, reference_image)
    try:
        subprocess.run(cmd, check=True, text=True, capture_output=True, timeout=timeout_seconds)
        return mmx_output_for(out_dir, out_prefix), False
    except subprocess.CalledProcessError as first_exc:
        if not reference_image:
            raise MmxProviderError(provider_error_excerpt(first_exc), False) from first_exc
        fallback_cmd = build_mmx_command(prompt, out_dir, out_prefix, fmt, seed, None)
        try:
            subprocess.run(fallback_cmd, check=True, text=True, capture_output=True, timeout=timeout_seconds)
        except subprocess.CalledProcessError as fallback_exc:
            message = (
                f"subject-ref command failed: {provider_error_excerpt(first_exc)}; "
                f"fallback command failed: {provider_error_excerpt(fallback_exc)}"
            )
            raise MmxProviderError(message, True) from fallback_exc
        return mmx_output_for(out_dir, out_prefix), True


def job_output_dir(job: dict) -> Path:
    return Path(job["out"]).expanduser()


def job_results_path(job: dict) -> Path:
    return job_output_dir(job) / "results.json"


def save_results(job: dict, results: list[dict]) -> None:
    remotion_manifest = [
        {
            "s_id": result.get("s_id"),
            "beat_ref": result.get("beat_ref"),
            "image_path": result.get("image_path"),
            "safe_areas": result.get("safe_areas", []),
            "overlay_labels": result.get("overlay_labels", []),
            "format": result.get("format"),
            "usable": result.get("usable", False),
        }
        for result in results
    ]
    write_json_file(
        job_results_path(job),
        {
            "job_id": job["job_id"],
            "status": job["status"],
            "records_count": len(job.get("records", [])),
            "results": results,
            "remotion_manifest": remotion_manifest,
            "updated_at": utc_now(),
        },
    )


def load_results(job: dict) -> list[dict]:
    path = job_results_path(job)
    if not path.exists():
        return []
    data = load_json_config(path)
    return data.get("results", [])


def load_results_payload(job: dict) -> dict:
    path = job_results_path(job)
    if not path.exists():
        return {"results": [], "remotion_manifest": []}
    return load_json_config(path)


def submit_job(records_path: Path, out: Path, job_root: Path, backend: str, retries: int, force: bool, timeout_seconds: int) -> dict:
    records_path = records_path.resolve()
    out = out.resolve()
    job_root = job_root.resolve()
    payload = read_json_file(records_path)
    records = normalize_records_payload(payload)
    errors = validate_records(records)
    if errors:
        raise ValueError("\n".join(errors))
    out.mkdir(parents=True, exist_ok=True)
    (out / "9x16").mkdir(exist_ok=True)
    (out / "16x9").mkdir(exist_ok=True)
    job_id = hashlib.sha256((str(records_path.resolve()) + stable_json(records) + utc_now()).encode("utf-8")).hexdigest()[:12]
    job_dir = job_path_for(job_root, job_id)
    job_dir.mkdir(parents=True, exist_ok=True)
    normalized_records = []
    for record in records:
        item = normalize_record_defaults(record)
        normalized_records.append(item)
    job = {
        "job_id": job_id,
        "status": "pending",
        "created_at": utc_now(),
        "updated_at": utc_now(),
        "records_path": str(records_path),
        "job_root": str(job_root),
        "out": str(out),
        "backend": backend,
        "backend_config": {"backend": backend, "model": "image-01" if backend == "mmx" else "mock", "region": "cn" if backend == "mmx" else None},
        "retries": max(0, retries),
        "force": force,
        "timeout_seconds": timeout_seconds,
        "records": normalized_records,
        "progress": {"total": len(normalized_records), "completed": 0, "failed": 0, "cached": 0},
        "errors": [],
    }
    save_job(job_dir, job)
    write_json_file(job_dir / "records.snapshot.json", {"records": normalized_records})
    append_event(job_dir, {"event": "submitted", "records": len(normalized_records)})
    return job


def cache_dir_for(job: dict) -> Path:
    return job_output_dir(job) / ".mrai-cache"


def generate_record(job: dict, record: dict, existing_results: list[dict]) -> dict:
    backend = job["backend"]
    fmt = record.get("format", "9x16")
    seed = int(hashlib.sha256(stable_json(record).encode("utf-8")).hexdigest()[:8], 16) % 100000
    prompt = prompt_for_record(record)
    backend_config = job["backend_config"]
    cache_key = cache_key_for_record(record, backend_config)
    cache_dir = cache_dir_for(job)
    image_dir = job_output_dir(job) / fmt
    version = next_version_for(image_dir, record["s_id"], fmt, job.get("force", False))
    safe_id = slugify(record["s_id"]).upper() or "S"
    cached_candidates = sorted(cache_dir.glob(f"{cache_key}_{fmt}.*"))

    if not job.get("force") and cached_candidates:
        cache_file = cached_candidates[0]
        target = image_dir / result_filename(record["s_id"], version, fmt, cache_file.suffix.lower().lstrip(".") or "png")
        target.parent.mkdir(parents=True, exist_ok=True)
        if not target.exists():
            shutil.copy2(cache_file, target)
        return build_result(record, str(target), version, True, backend, prompt, seed, 0)

    attempts = max(1, int(job.get("retries", 0)) + 1)
    last_error: Exception | None = None
    last_subject_ref_failed = False
    for attempt in range(1, attempts + 1):
        subject_ref_failed = False
        try:
            if backend == "mock":
                target = image_dir / result_filename(record["s_id"], version, fmt, "png")
                if record.get("mock_provider_error"):
                    raise RuntimeError(str(record.get("mock_provider_error")))
                write_mock_image(target)
            elif backend == "mmx":
                out_prefix = f"{safe_id}_v{version}_{fmt}"
                produced, subject_ref_failed = run_mmx_provider(
                    prompt,
                    image_dir,
                    out_prefix,
                    fmt,
                    seed,
                    int(job.get("timeout_seconds", 1800)),
                    record.get("reference_image"),
                )
                target = image_dir / result_filename(record["s_id"], version, fmt, produced.suffix.lower().lstrip(".") or "png")
                if produced != target:
                    produced.rename(target)
            else:
                raise RuntimeError(f"unsupported backend {backend}")
            if not subject_ref_failed:
                cache_file = cache_dir / f"{cache_key}_{fmt}{target.suffix.lower() or '.png'}"
                cache_file.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(target, cache_file)
            return build_result(
                record,
                str(target),
                version,
                False,
                backend,
                prompt,
                seed,
                attempt,
                qa_status_override="warning" if backend == "mmx" and subject_ref_failed else None,
                subject_ref_failed=backend == "mmx" and subject_ref_failed,
            )
        except subprocess.TimeoutExpired as exc:
            last_error = exc
            error_code = "timeout"
        except FileNotFoundError as exc:
            last_error = exc
            error_code = "provider_missing"
        except MmxProviderError as exc:
            last_error = exc
            last_subject_ref_failed = exc.subject_ref_failed
            error_code = "provider_failed"
        except Exception as exc:  # noqa: BLE001 - CLI must report provider errors.
            last_error = exc
            error_code = "provider_failed"
        if attempt >= attempts:
            return build_result(
                record,
                None,
                version,
                False,
                backend,
                prompt,
                seed,
                attempt,
                error_code,
                str(last_error),
                subject_ref_failed=backend == "mmx" and last_subject_ref_failed,
            )
    return build_result(record, None, version, False, backend, prompt, seed, attempts, "provider_failed", "unknown provider failure")


def run_job(job_dir: Path, force: bool | None = None) -> dict:
    job = load_job(job_dir)
    if job.get("status") not in JOB_STATUSES:
        raise ValueError(f"invalid job status {job.get('status')!r}")
    if force is not None:
        job["force"] = force
    if job.get("backend") == "mmx" and shutil.which("mmx") is None:
        job["status"] = "failed"
        job["errors"] = [{"error_code": "provider_missing", "error_message": "mmx CLI not found"}]
        save_job(job_dir, job)
        save_results(job, [])
        append_event(job_dir, {"event": "failed", "error_code": "provider_missing", "error_message": "mmx CLI not found"})
        return job
    job["status"] = "running"
    save_job(job_dir, job)
    append_event(job_dir, {"event": "running"})
    results: list[dict] = []
    completed = failed = cached = 0
    for record in job.get("records", []):
        result = generate_record(job, record, results)
        results.append(result)
        if result.get("cache_hit"):
            cached += 1
        if result.get("error_code"):
            failed += 1
            append_event(job_dir, {"event": "record_failed", "s_id": record.get("s_id"), "error_code": result.get("error_code")})
        else:
            completed += 1
            append_event(job_dir, {"event": "record_completed", "s_id": record.get("s_id"), "cache_hit": result.get("cache_hit")})
        job["progress"] = {"total": len(job.get("records", [])), "completed": completed, "failed": failed, "cached": cached}
        save_results(job, results)
        save_job(job_dir, job)
    job["status"] = "completed"
    job["progress"] = {"total": len(job.get("records", [])), "completed": completed, "failed": failed, "cached": cached}
    save_job(job_dir, job)
    save_results(job, results)
    append_event(job_dir, {"event": "completed", "completed": completed, "failed": failed, "cached": cached})
    return job


def query_job(job_dir: Path) -> dict:
    job = load_job(job_dir)
    results_payload = load_results_payload(job)
    return {
        "job_id": job.get("job_id"),
        "status": job.get("status"),
        "progress": job.get("progress"),
        "out": job.get("out"),
        "backend": job.get("backend"),
        "results": results_payload.get("results", []),
        "remotion_manifest": results_payload.get("remotion_manifest", []),
        "errors": job.get("errors", []),
        "updated_at": job.get("updated_at"),
    }


def contains_any(text: str, keywords: list[str]) -> bool:
    lowered = text.lower()
    return any(keyword.lower() in lowered for keyword in keywords)


def count_keywords(text: str, keywords: list[str]) -> int:
    lowered = text.lower()
    return sum(lowered.count(keyword.lower()) for keyword in keywords)


def style_rules(routing: dict, style: str) -> dict:
    return routing["styles"].get(style, routing["styles"][routing["defaults"]["default_style"]])


def find_layout_rule(routing: dict, style: str, layout: str) -> dict | None:
    for rule in style_rules(routing, style).get("rules", []):
        if rule.get("layout") == layout:
            return rule
    for style_config in routing["styles"].values():
        for rule in style_config.get("rules", []):
            if rule.get("layout") == layout:
                return rule
    return None


def layout_spec(layout_library: dict, layout: str) -> dict:
    return layout_library.get("layouts", {}).get(layout, {})


def parse_csv_ids(value: str | None) -> set[str]:
    if not value:
        return set()
    return {item.strip().upper() for item in value.split(",") if item.strip()}


def parse_visual_override(text: str) -> dict[str, str]:
    match = re.search(r"<!--\s*visual:\s*(.*?)\s*-->", text, re.IGNORECASE | re.DOTALL)
    if not match:
        return {}
    result: dict[str, str] = {}
    for part in match.group(1).split(","):
        if ":" not in part:
            continue
        key, value = part.split(":", 1)
        result[key.strip().lower()] = value.strip()
    return result


def strip_visual_comments(text: str) -> str:
    return re.sub(r"<!--\s*visual:.*?\s*-->", "", text, flags=re.IGNORECASE | re.DOTALL).strip()


def slugify(text: str) -> str:
    text = text.strip().lower()
    text = re.sub(r"[^\w\u4e00-\u9fff]+", "-", text)
    text = re.sub(r"-+", "-", text).strip("-")
    return text or "mr-ai-task"


def parse_script_segments(script: str) -> list[ScriptSegment]:
    """Parse standard S/B video scripts while ignoring later editorial notes."""
    script = script.strip()
    heading_pattern = re.compile(
        r"(?m)^\s{0,3}(?:#{1,6}\s*)?([SB])(\d+)\s*[·.\-:：]?\s*([^\n]*)$",
        re.IGNORECASE,
    )
    matches = list(heading_pattern.finditer(script))
    if not matches:
        sections = split_sections_fallback(script)
        return [
            ScriptSegment(
                role="S",
                number=str(i),
                title=title,
                body=strip_visual_comments(body),
                raw_title=title,
                index=i,
                visual_override=parse_visual_override(body),
            )
            for i, (title, body) in enumerate(sections, start=1)
        ]

    segments: list[ScriptSegment] = []
    for index, match in enumerate(matches, start=1):
        start = match.end()
        next_match_start = matches[index].start() if index < len(matches) else len(script)
        body = script[start:next_match_start]
        editorial = re.search(r"(?m)^\s{0,3}#{1,2}\s+(主要改动|保留的事实|仍需人工|删除或弱化|口播节奏|备注|附录)", body)
        if editorial:
            body = body[: editorial.start()]
        body = body.strip()
        if not body:
            continue
        visual_override = parse_visual_override(body)
        body = strip_visual_comments(body)
        role = match.group(1).upper()
        number = match.group(2)
        title = match.group(3).strip() or f"{role}{number}"
        raw_title = f"{role}{number} · {title}"
        segments.append(
            ScriptSegment(
                role=role,
                number=number,
                title=title,
                body=body,
                raw_title=raw_title,
                index=index,
                visual_override=visual_override,
            )
        )
    return segments


def split_sections_fallback(script: str) -> list[tuple[str, str]]:
    script = re.sub(r"(?<!\n)([一二三四五六七八九十]、)", r"\n\1", script)
    chinese_matches = list(re.finditer(r"(?m)^([一二三四五六七八九十]、)", script))
    if chinese_matches:
        sections = []
        for i, match in enumerate(chinese_matches):
            section_start = match.start()
            end = chinese_matches[i + 1].start() if i + 1 < len(chinese_matches) else len(script)
            section_text = script[section_start:end].strip()
            title_match = re.match(r"([一二三四五六七八九十]、.{1,80}?[？。:：])", section_text)
            if title_match:
                title = title_match.group(1).strip()
                body = section_text[title_match.end():].strip()
            else:
                title = section_text[:80].strip()
                body = section_text[80:].strip()
            if body:
                sections.append((title, body))
        return sections

    paragraphs = [p.strip() for p in re.split(r"\n\s*\n", script) if p.strip()]
    return [(f"Section {i+1}", p) for i, p in enumerate(paragraphs)]


def split_sections(script: str) -> list[tuple[str, str]]:
    segments = parse_script_segments(script)
    if segments:
        return [(segment.raw_title, segment.body) for segment in segments]

    script = re.sub(r"(?<!\n)([一二三四五六七八九十]、)", r"\n\1", script)
    matches = list(re.finditer(r"(?m)^(#{1,4}\s*)?(S\d+[^。\n]*|###\s*S\d+[^。\n]*|##\s*S\d+[^。\n]*)\n", script))
    if not matches:
        chinese_matches = list(re.finditer(r"(?m)^([一二三四五六七八九十]、)", script))
        if chinese_matches:
            sections = []
            for i, match in enumerate(chinese_matches):
                section_start = match.start()
                end = chinese_matches[i + 1].start() if i + 1 < len(chinese_matches) else len(script)
                section_text = script[section_start:end].strip()
                title_match = re.match(r"([一二三四五六七八九十]、.{1,80}?[？。:：])", section_text)
                if title_match:
                    title = title_match.group(1).strip()
                    body = section_text[title_match.end():].strip()
                else:
                    title = section_text[:80].strip()
                    body = section_text[80:].strip()
                if body:
                    sections.append((title, body))
            return sections
    if not matches:
        paragraphs = [p.strip() for p in re.split(r"\n\s*\n", script) if p.strip()]
        return [(f"Section {i+1}", p) for i, p in enumerate(paragraphs)]

    sections: list[tuple[str, str]] = []
    for i, match in enumerate(matches):
        start = match.end()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(script)
        title = re.sub(r"^#+\s*", "", match.group(0)).strip()
        body = script[start:end].strip()
        if body:
            sections.append((title, body))
    return sections


def summarize(text: str, limit: int = 72) -> str:
    lines = []
    for line in text.splitlines():
        stripped = line.strip()
        if re.search(r"^(if|elif|else|while|for)\b|=|_{2,}|\(|\)", stripped) and len(stripped) < 120:
            continue
        lines.append(stripped)
    clean = re.sub(r"\s+", "", "".join(lines) or text)
    return clean[:limit] + ("..." if len(clean) > limit else "")


def make_overlay_text(config: dict, text: str, layout: str | None = None, limit: int = 7) -> str:
    """Produce a short overlay seed, not a subtitle excerpt."""
    lowered = text.lower()
    for keyword in config.get("overlay", {}).get("keywords", []):
        if keyword.lower() in lowered:
            return keyword[:limit]
    layout_labels = config.get("overlay", {}).get("layout_labels", {})
    if layout and layout in layout_labels:
        return layout_labels[layout]
    clean = re.sub(r"[“”\"'《》。，、：:；;！？!?（）()\[\]【】\s]+", "", text)
    return clean[:limit]


def yaml_string(text: str) -> str:
    return json.dumps(text, ensure_ascii=False)


def choose_layout(config: dict, text: str, style: str = "brand") -> str:
    style_config = style_rules(config, style)
    for rule in style_config.get("rules", []):
        if contains_any(text, rule.get("match", [])):
            return rule["layout"]
    return style_config["default_layout"]


def choose_diverse_layout(config: dict, layout: str, style: str, text: str, used_layouts: dict[str, int]) -> str:
    layout_key = f"{style}:{layout}"
    max_same_layout = config["defaults"]["max_same_layout"]
    if used_layouts.get(layout_key, 0) < max_same_layout:
        return layout

    for rule in style_rules(config, style).get("rules", []):
        preferred = rule.get("layout")
        if rule.get("prefer_when_repeated") and contains_any(text, rule.get("match", [])):
            if used_layouts.get(f"{style}:{preferred}", 0) < max_same_layout:
                return preferred

    fallback_layouts = style_rules(config, style).get("fallbacks", [])

    return next(
        (
            candidate
            for candidate in fallback_layouts
            if candidate != layout and used_layouts.get(f"{style}:{candidate}", 0) < max_same_layout
        ),
        layout,
    )


def action_for_layout(layout_library: dict, layout: str) -> str:
    spec = layout_spec(layout_library, layout)
    return spec.get("action", "Mr.Ai explains the concept through one small physical action.")


def labels_for_layout(layout_library: dict, layout: str) -> list[str]:
    spec = layout_spec(layout_library, layout)
    return spec.get("labels", ["概念", "动作", "结果"])


def score_segment(treatment: dict, segment: ScriptSegment) -> int:
    text = segment.raw_title + segment.body
    scoring = treatment["segment_scoring"]
    score = count_keywords(text, scoring.get("keywords", []))
    if segment.role == "B":
        score -= scoring.get("quoted_source_penalty", 6)
    if contains_any(segment.title, scoring.get("title_bonus_keywords", [])):
        score += 2
    return score


def first_matching_rule(rules: list[dict], text: str, default: dict) -> dict:
    for rule in rules:
        if contains_any(text, rule.get("match", [])):
            return rule
    return default


def classify_cognitive_role(treatment: dict, segment: ScriptSegment) -> tuple[str, str]:
    override = segment.override
    if override.get("cognitive_role"):
        return override["cognitive_role"], override.get("visual_purpose", "Use the explicit cognitive role override.")
    if segment.role == "B":
        return "quote_source", "Preserve quoted source meaning; use quote card or overlay instead of metaphor rewriting."
    default = {
        "role": "explanation",
        "visual_purpose": "Support the voiceover only if a visual metaphor reduces explanation time.",
    }
    rule = first_matching_rule(treatment.get("cognitive_roles", []), segment.raw_title + segment.body, default)
    return rule["role"], rule["visual_purpose"]


def classify_expression_pace(treatment: dict, segment: ScriptSegment) -> tuple[str, str]:
    override = segment.override
    if override.get("pace"):
        return override["pace"], override.get("timing_hint", "Use explicit timing override.")
    if segment.role == "B":
        return "quote", "hold quote card or overlay without metaphorical rewriting"
    default = {"pace": "explain", "timing_hint": "keep voiceover primary"}
    rule = first_matching_rule(treatment.get("expression_pacing", []), segment.raw_title + segment.body, default)
    return rule["pace"], rule["timing_hint"]


def pick_segments(treatment: dict, segments: list[ScriptSegment], max_shots: int, forced_ids: set[str] | None = None) -> list[ScriptSegment]:
    forced_ids = forced_ids or set()
    candidates = [segment for segment in segments if segment.role == "S"]
    forced = [segment for segment in candidates if segment.segment_id.upper() in forced_ids]
    remaining = [segment for segment in candidates if segment.segment_id.upper() not in forced_ids]
    scored = [(score_segment(treatment, segment), segment.index, segment) for segment in remaining]
    scored.sort(key=lambda item: (-item[0], item[1]))
    chosen = forced + [segment for _, _, segment in scored[: max(0, max_shots - len(forced))]]
    return sorted(chosen[:max_shots], key=lambda segment: segment.index)


def choose_style_for_segment(config: dict, segment: ScriptSegment, requested_style: str) -> str:
    if requested_style != "auto":
        return requested_style
    override = segment.override
    if override.get("style") in config["styles"]:
        return override["style"]
    text = segment.raw_title + segment.body
    brand_score = count_keywords(text, style_rules(config, "brand").get("triggers", []))
    explainer_score = count_keywords(text, style_rules(config, "explainer-sketch").get("triggers", []))
    if brand_score > explainer_score:
        return "brand"
    if explainer_score > 0:
        return "explainer-sketch"
    if brand_score > 0:
        return "brand"
    return config["defaults"]["default_style"]


def visual_treatment_for_segment(treatment: dict, segment: ScriptSegment, selected: bool, style: str) -> str:
    override = segment.override
    if override.get("treatment"):
        return override["treatment"]
    if segment.role == "B":
        return treatment.get("role_treatments", {}).get("B", {}).get("default", "quote-card-or-overlay")
    if selected:
        return style
    return treatment.get("role_treatments", {}).get("S", {}).get("unselected", "subtitle-or-no-image")


def timing_for_segment(treatment: dict, segment: ScriptSegment, selected: bool) -> str:
    override = segment.override
    if override.get("timing"):
        return override["timing"]
    if segment.role == "B":
        return treatment.get("role_treatments", {}).get("B", {}).get("timing", "hold_during_quote")
    if selected:
        return treatment.get("role_treatments", {}).get("S", {}).get("selected_timing", "sync_with_voiceover_anchor")
    return treatment.get("role_treatments", {}).get("S", {}).get("unselected_timing", "keep_voiceover_primary")


def prompt_for(title: str, summary: str, layout: str, action: str, labels: list[str], fmt: str, style: str) -> str:
    orientation = "16:9 horizontal" if fmt == "16x9" else "9:16 vertical"
    safe = "Leave quiet blank space on the right side." if fmt == "16x9" else "Keep safe blank space at the top and bottom for subtitles."
    overlay_labels = " / ".join(labels)
    if style == "explainer-sketch":
        return textwrap.dedent(
            f"""\
            Generate one standalone Mr.Ai whiteboard explanatory sketch for the AI 闲僧 video column.

            Format:
            {orientation}. Clean white background with generous empty space for later subtitles and video overlays.

            Brand character:
            Mr.Ai is a friendly middle-aged AI explainer with a baseball cap with a curved brim, clearly visible gray/dark mustache, rounded cartoon face, simple blue shirt, thick dark outline, and a tiny yellow brand accent. Draw him small but readable, about 10-18% of the canvas in 16:9 or 16-26% in 9:16, as the person performing the explanatory action. Do not make him a robot, monk, child, black silhouette, or formal business presenter.

            Visual style:
            Hand-drawn whiteboard explanation, thin black marker lines, sparse props, rough human sketch feeling, no polished render, no glossy shading, no full scene background. Use mostly unfilled black line art. Use blue only for Mr.Ai's shirt or the main process line, yellow only for one small highlight, red only for warnings. Avoid large filled color areas. The image should feel closer to a simple explanatory sketch than a finished poster.

            Theme:
            {title}

            Core idea:
            {summary}

            Structure type:
            {layout}

            Composition:
            {action} Use one physical metaphor only. Use thin arrows or a single route line if needed. {safe}

            Overlay labels for post-production only:
            {overlay_labels}

            Constraints:
            One image explains only one core idea. Do NOT render Chinese characters in the image. Leave all label cards, signs, and text spaces blank so exact Chinese can be added in post-production overlay. If a model insists on text, use simple blank lines, roman numerals, or abstract symbols only. No title, no paragraphs, no subtitles, no decorative background, no PPT infographic, no math equation, no plus-sign formula, no dense architecture diagram, no stock vector, no realistic UI screenshot, no sci-fi interface, no robot icon, no robot face, no children's-book scene. Preserve Mr.Ai's cap, mustache, blue clothing, yellow accent, and rounded middle-aged cartoon identity.
            """
        )
    return textwrap.dedent(
        f"""\
        Generate one standalone Mr.Ai brand illustration for the AI 闲僧 video column.

        Format:
        {orientation}. Clean composition with safe space for later subtitles and video overlays.

        Brand character:
        Mr.Ai is a friendly middle-aged AI explainer with a baseball cap with a curved brim, clearly visible gray/dark mustache, rounded cartoon face, blue shirt, thick dark outline, and yellow brand accent. He must perform the core conceptual action, not stand as decoration. Keep him warm, calm, curious, and practical. Do not make him a robot, monk, child, black silhouette, or formal business presenter.

        Visual style:
        Colored cartoon brand IP plus clean explanatory sketch logic. White or very light background, simple conceptual props, restrained blue/yellow brand color, dark outlines, small red warnings only when needed.

        Theme:
        {title}

        Core idea:
        {summary}

        Structure type:
        {layout}

        Composition:
        {action} Use blank label cards or very short labels only. {safe}

        Overlay labels for post-production only:
        {overlay_labels}

        Constraints:
        One image explains only one core idea. Do NOT render Chinese characters in the image. Leave all label cards, signs, and text spaces blank so exact Chinese can be added in post-production overlay. If a model insists on text, use simple blank lines, roman numerals, or abstract symbols only. Do not write a long title, paragraph, subtitle, or structure type on the image. Do not make it a PPT infographic, math equation, plus-sign formula, dense architecture diagram, stock vector, generic mascot poster, realistic UI screenshot, sci-fi interface, or children's illustration. Preserve Mr.Ai's cap, mustache, blue clothing, yellow accent, and rounded middle-aged cartoon identity.
        """
    )


def asset_slots_for_shot(shot_id: str) -> dict[str, str]:
    return {
        "16x9": f"16x9/{shot_id}-16x9.png",
        "9x16": f"9x16/{shot_id}-9x16.png",
    }


def write_package(
    script: str,
    out: Path,
    title: str,
    max_shots: int,
    style: str,
    routing_path: Path,
    layout_library_path: Path,
    treatment_rules_path: Path,
    forced_segments: set[str] | None = None,
    prefer_layout: str | None = None,
) -> None:
    routing = load_json_config(routing_path)
    layout_library = load_json_config(layout_library_path)
    treatment_rules = load_json_config(treatment_rules_path)
    formats = routing.get("defaults", {}).get("formats", ["16x9", "9x16"])
    out.mkdir(parents=True, exist_ok=True)
    (out / "16x9").mkdir(exist_ok=True)
    (out / "9x16").mkdir(exist_ok=True)
    (out / "16x9" / ".gitkeep").write_text("", encoding="utf-8")
    (out / "9x16" / ".gitkeep").write_text("", encoding="utf-8")
    (out / "source-script.md").write_text(script.strip() + "\n", encoding="utf-8")

    segments = parse_script_segments(script)
    chosen_segments = pick_segments(treatment_rules, segments, max_shots, forced_segments)
    chosen_ids = {segment.segment_id for segment in chosen_segments}

    shot_lines = ["# Shot List", "", f"- Topic: {title}", f"- Style preset: {style}", "- Status: generated by `mrai gen`, review before production", ""]
    prompt_lines = ["# Image Prompts", "", "These prompts are a first-pass scaffold. Review and tighten before production image generation.", f"Style preset: `{style}`", ""]
    overlay_lines = ["# Optional Remotion Overlay Notes", ""]
    timeline_lines = [
        "# Timeline Plan",
        "",
        f"- Topic: {title}",
        f"- Style preset: {style}",
        "- Purpose: keep voiceover meaning, image choice, overlay text, and timing aligned.",
        "",
    ]
    audio_visual_map = {
        "topic": title,
        "style_preset": style,
        "segments": [],
        "shots": [],
    }
    asset_manifest = {
        "topic": title,
        "image_policy": "Generate images into the recommended asset slots. Keep Chinese text out of bitmap images; add exact labels in post-production overlays.",
        "assets": [],
    }

    used_layouts: dict[str, int] = {}
    for segment in segments:
        shot_style = choose_style_for_segment(routing, segment, style)
        selected = segment.segment_id in chosen_ids
        segment_treatment = visual_treatment_for_segment(treatment_rules, segment, selected, shot_style)
        timing = timing_for_segment(treatment_rules, segment, selected)
        cognitive_role, segment_visual_purpose = classify_cognitive_role(treatment_rules, segment)
        expression_pace, timing_hint = classify_expression_pace(treatment_rules, segment)
        summary = summarize(segment.body, 80)
        overlay_text = make_overlay_text(routing, segment.body)
        timeline_lines.extend(
            [
                f"## {segment.segment_id} · {segment.title}",
                "",
                f"- Role: {'host voiceover' if segment.role == 'S' else 'quoted source'}",
                f"- Visual treatment: {segment_treatment}",
                f"- Cognitive role: {cognitive_role}",
                f"- Expression pace: {expression_pace}",
                f"- Timing: {timing}",
                f"- Timing hint: {timing_hint}",
                f"- Visual purpose: {segment_visual_purpose}",
                f"- Voiceover anchor: {summary}",
                f"- Script summary excerpt: {summary[:28]}",
                f"- Overlay text candidate: {overlay_text}",
                "- Note: B segments should preserve quoted meaning; prefer quote cards or overlays instead of metaphorical rewriting." if segment.role == "B" else "- Note: Use an image only if it reduces explanation time; otherwise let voiceover and subtitles lead.",
                "",
            ]
        )
        audio_visual_map["segments"].append(
            {
                "segment_id": segment.segment_id,
                "role": "host_voiceover" if segment.role == "S" else "quoted_source",
                "title": segment.title,
                "voiceover_summary": summary,
                "script_summary_excerpt": summary[:28],
                "selected_for_image": selected,
                "visual_treatment": segment_treatment,
                "cognitive_role": cognitive_role,
                "expression_pace": expression_pace,
                "visual_purpose": segment_visual_purpose,
                "timing": timing,
                "timing_hint": timing_hint,
                "overlay_text_candidate": overlay_text,
            }
        )

    for idx, segment in enumerate(chosen_segments, start=1):
        section_title = segment.raw_title
        body = segment.body
        shot_style = choose_style_for_segment(routing, segment, style)
        section_text = section_title + body
        layout = segment.override.get("layout") or prefer_layout or choose_layout(routing, section_text, shot_style)
        layout = choose_diverse_layout(routing, layout, shot_style, section_text, used_layouts)
        layout_key = f"{shot_style}:{layout}"
        used_layouts[layout_key] = used_layouts.get(layout_key, 0) + 1
        override_labels = segment.override.get("labels", "")
        labels = [item.strip() for item in override_labels.split("|") if item.strip()] if override_labels else labels_for_layout(layout_library, layout)
        action = segment.override.get("action") or action_for_layout(layout_library, layout)
        shot_id = f"{idx:02d}-{segment.segment_id.lower()}-{slugify(layout)[:42]}"
        asset_slots = asset_slots_for_shot(shot_id)
        summary = summarize(body)
        overlay_text = make_overlay_text(routing, section_text, layout)
        cognitive_role, segment_visual_purpose = classify_cognitive_role(treatment_rules, segment)
        expression_pace, timing_hint = classify_expression_pace(treatment_rules, segment)
        audio_visual_map["shots"].append(
            {
                "shot_id": shot_id,
                "segment_id": segment.segment_id,
                "segment_role": "host_voiceover",
                "formats": formats,
                "style_preset": shot_style,
                "structure_type": layout,
                "cognitive_role": cognitive_role,
                "expression_pace": expression_pace,
                "timing": "sync_with_voiceover_anchor",
                "timing_hint": timing_hint,
                "voiceover_summary": summary,
                "script_summary_excerpt": summary[:28],
                "visual_purpose": segment_visual_purpose,
                "mr_ai_action": action,
                "short_labels": labels,
                "asset_slots": asset_slots,
                "overlay_text_candidate": overlay_text,
            }
        )
        asset_manifest["assets"].append(
            {
                "shot_id": shot_id,
                "segment_id": segment.segment_id,
                "formats": formats,
                "asset_slots": asset_slots,
                "style_preset": shot_style,
                "structure_type": layout,
                "overlay_text_candidate": overlay_text,
                "short_labels": labels,
                "status": "pending_generation",
            }
        )

        shot_lines.extend(
            [
                f"## {shot_id}",
                "",
                "```yaml",
                f"id: {shot_id}",
                f"script_position: {section_title}",
                f"script_segment: {segment.segment_id}",
                "segment_role: host_voiceover",
                f"voiceover_summary: {yaml_string(summary)}",
                f"cognitive_role: {cognitive_role}",
                f"expression_pace: {expression_pace}",
                f"visual_purpose: {segment_visual_purpose}",
                "format: both",
                f"formats: {json.dumps(formats)}",
                f"structure_type: {layout}",
                f"style_preset: {shot_style}",
                "image_timing: sync_with_voiceover_anchor",
                f"timing_hint: {timing_hint}",
                f"mr_ai_action: {action}",
                f"main_metaphor: {layout}",
                f"short_labels: {json.dumps(labels, ensure_ascii=False)}",
                f"asset_slots: {json.dumps(asset_slots, ensure_ascii=False)}",
                "prompt_status: draft",
                "qa_status: pending review",
                "```",
                "",
            ]
        )

        prompt_lines.extend(
            [
                f"## {shot_id}",
                "",
                "### 16:9",
                "",
                "```text",
                prompt_for(section_title, summary, layout, action, labels, "16x9", shot_style).strip(),
                "```",
                "",
                "### 9:16",
                "",
                "```text",
                prompt_for(section_title, summary, layout, action, labels, "9x16", shot_style).strip(),
                "```",
                "",
            ]
        )

        overlay_lines.extend(
            [
                f"## {shot_id}",
                "",
                f"- Script summary excerpt: {summary[:28]}",
                f"- Overlay text candidate: {overlay_text}",
                "- Add exact Chinese text in post-production if the generated bitmap text drifts.",
                "- Keep subtitles outside the main character and prop area.",
                "",
            ]
        )

    qa = textwrap.dedent(
        """\
        # QA Report

        ## Package-level checks

        - Character consistency: pending generated images.
        - Concept clarity: review every shot before generation.
        - Timeline fit: check `timeline-plan.md` before image generation.
        - Text safety: prefer blank label cards or 1-3 short labels.
        - Format safety: both 16:9 and 9:16 prompts created.
        - Brand fit: pending generated images.

        ## Known risks

        - This CLI uses deterministic routing rules; an agent should refine the shot choices.
        - Production default is blank in-image labels; add exact Chinese in post-production.
        - Workflow layouts can drift toward formal PPT diagrams, equations, or three-box slides.
        - Explainer-sketch layouts can drift back into polished brand posters if Mr.Ai is too large or the props are too detailed.
        - S/B parsing is deterministic; review whether B segments should be quote cards, overlays, or skipped.
        """
    )

    validation = textwrap.dedent(
        """\
        # Validation Notes

        ## How to use this package

        1. Review `shot-list.md`.
        2. Review `timeline-plan.md` and confirm the selected images match the voiceover segments.
        3. Tighten the best 2-3 prompts in `image-prompts.md`.
        4. Generate only 2-3 images for the first validation.
        5. Record usable images, failures, and rule changes here.

        ## Review questions

        - Did Mr.Ai keep cap, mustache, blue clothing, and yellow accent?
        - Did each image explain one idea?
        - Did each image appear at the right voiceover moment?
        - Were B quote segments preserved instead of distorted into new claims?
        - Did text need to move to post-production?
        - Which layout pattern worked best?
        """
    )

    (out / "shot-list.md").write_text("\n".join(shot_lines), encoding="utf-8")
    (out / "image-prompts.md").write_text("\n".join(prompt_lines), encoding="utf-8")
    (out / "timeline-plan.md").write_text("\n".join(timeline_lines), encoding="utf-8")
    (out / "audio-visual-map.json").write_text(json.dumps(audio_visual_map, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    (out / "asset-manifest.json").write_text(json.dumps(asset_manifest, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    (out / "remotion-overlay-notes.md").write_text("\n".join(overlay_lines), encoding="utf-8")
    (out / "qa-report.md").write_text(qa, encoding="utf-8")
    (out / "validation-notes.md").write_text(validation, encoding="utf-8")


def main() -> int:
    parser = argparse.ArgumentParser(prog="mrai", description="Create Mr.Ai illustration packages.")
    sub = parser.add_subparsers(dest="command", required=True)
    gen = sub.add_parser("gen", help="Generate a prompt package from a script path or inline text.")
    gen.add_argument("input", help="Script file path or inline script text.")
    gen.add_argument("--out", required=True, help="Output directory.")
    gen.add_argument("--title", default="Mr.Ai validation task", help="Task title.")
    gen.add_argument("--max-shots", type=int, default=5, help="Maximum shot concepts.")
    gen.add_argument(
        "--style",
        choices=["brand", "explainer-sketch", "auto"],
        default="brand",
        help="Visual preset: brand for polished Mr.Ai illustrations, explainer-sketch for xiaohei-like whiteboard explanations, auto for per-segment recommendations.",
    )
    gen.add_argument(
        "--routing",
        default=str(DEFAULT_ROUTING_PATH),
        help="Path to visual routing rules JSON. Defaults to agent-pack/visual-routing-rules.json.",
    )
    gen.add_argument(
        "--layout-library",
        default=str(DEFAULT_LAYOUT_LIBRARY_PATH),
        help="Path to layout library JSON. Defaults to agent-pack/layout-library.json.",
    )
    gen.add_argument(
        "--treatment-rules",
        default=str(DEFAULT_TREATMENT_RULES_PATH),
        help="Path to treatment rules JSON. Defaults to agent-pack/treatment-rules.json.",
    )
    gen.add_argument(
        "--segments",
        help="Optional comma-separated S segment IDs to force into the shot list, for example S2,S4,S7.",
    )
    gen.add_argument(
        "--prefer-layout",
        help="Optional layout override for selected shots, for example 'Third Path'. Inline visual comments still take priority.",
    )
    validate = sub.add_parser("validate", help="Validate a generated Mr.Ai package and its audio-visual-map contract.")
    validate.add_argument("package", help="Generated package directory.")
    validate.add_argument(
        "--schema",
        default=str(DEFAULT_AV_SCHEMA_PATH),
        help="Path to audio-visual-map schema JSON. Defaults to agent-pack/audio-visual-map.schema.json.",
    )
    assets = sub.add_parser("assets", help="List expected image asset slots and whether files exist.")
    assets.add_argument("package", help="Generated package directory.")
    submit = sub.add_parser("submit", help="Submit B-side records as a local image generation job.")
    submit.add_argument("records", help="records.json path. Accepts records[] or a top-level list.")
    submit.add_argument("--out", required=True, help="Output directory for job files, images, and results.json.")
    submit.add_argument("--job-root", default=".", help="Directory containing .mrai-jobs/. Defaults to cwd.")
    submit.add_argument("--backend", choices=["mock", "mmx"], default="mmx", help="Image backend. Use mock for tests/offline validation.")
    submit.add_argument("--retries", type=int, default=2, help="Retries per record after the first attempt.")
    submit.add_argument("--force", action="store_true", help="Bypass cache and generate the next image version.")
    submit.add_argument("--timeout-seconds", type=int, default=1800, help="Provider timeout per image.")
    run_cmd = sub.add_parser("run", help="Run a submitted local job.")
    run_cmd.add_argument("job_id", help="Job id returned by submit.")
    run_cmd.add_argument("--root", default=".", help="Directory containing .mrai-jobs/. Defaults to cwd.")
    run_cmd.add_argument("--force", action="store_true", help="Bypass cache and generate the next image version for this run.")
    query_cmd = sub.add_parser("query", help="Query a submitted local job.")
    query_cmd.add_argument("job_id", help="Job id returned by submit.")
    query_cmd.add_argument("--root", default=".", help="Directory containing .mrai-jobs/. Defaults to cwd.")

    args = parser.parse_args()
    if args.command == "gen":
        script = read_input(args.input)
        write_package(
            script,
            Path(args.out),
            args.title,
            max(1, args.max_shots),
            args.style,
            Path(args.routing).expanduser(),
            Path(args.layout_library).expanduser(),
            Path(args.treatment_rules).expanduser(),
            parse_csv_ids(args.segments),
            args.prefer_layout,
        )
        print(f"Wrote Mr.Ai package to {args.out}")
        return 0
    if args.command == "validate":
        errors = validate_package(Path(args.package).expanduser(), Path(args.schema).expanduser())
        if errors:
            for error in errors:
                print(error)
            return 1
        print(f"Package is valid: {args.package}")
        return 0
    if args.command == "assets":
        lines, errors = asset_inventory(Path(args.package).expanduser())
        for line in lines:
            print(line)
        if errors:
            for error in errors:
                print(error)
            return 1
        return 0
    if args.command == "submit":
        try:
            job = submit_job(
                Path(args.records).expanduser(),
                Path(args.out).expanduser(),
                Path(args.job_root).expanduser(),
                args.backend,
                args.retries,
                args.force,
                args.timeout_seconds,
            )
        except (ValueError, json.JSONDecodeError, OSError) as exc:
            print(validation_error(f"invalid_record: {exc}"))
            return 1
        print(json.dumps({"job_id": job["job_id"], "status": job["status"], "job_root": job["job_root"], "out": job["out"]}, ensure_ascii=False, indent=2))
        return 0
    if args.command == "run":
        job_dir = job_path_for(Path(args.root).expanduser(), args.job_id)
        if not job_dir.exists():
            print(validation_error(f"job not found: {args.job_id}"))
            return 1
        try:
            job = run_job(job_dir, force=True if args.force else None)
        except Exception as exc:  # noqa: BLE001 - top-level CLI error reporting.
            print(validation_error(f"job failed: {exc}"))
            return 1
        print(json.dumps(query_job(job_dir), ensure_ascii=False, indent=2))
        return 0 if job["status"] == "completed" else 1
    if args.command == "query":
        job_dir = job_path_for(Path(args.root).expanduser(), args.job_id)
        if not job_dir.exists():
            print(validation_error(f"job not found: {args.job_id}"))
            return 1
        print(json.dumps(query_job(job_dir), ensure_ascii=False, indent=2))
        return 0
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
